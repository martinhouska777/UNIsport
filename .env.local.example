# Supabase — copy this file to ".env.local" and fill in the values.
# Find them in your Supabase dashboard: Project Settings (gear) -> API.
# (.env.local is gitignored — these never get committed.)

# Project URL, e.g. https://abcdxyz.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# "anon" / "public" key (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Web Push (VAPID) — for real notifications. Generate a pair once with:
#   npx web-push generate-vapid-keys --json
# Public key is browser-safe; the private key is server-only (never expose it).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# A contact URL the push service can reach you at, e.g. mailto:you@example.com
VAPID_SUBJECT=
